# Frontend environment variables
# Copy this file to .env.local for local development

# The base URL of your Django backend (no trailing slash)
REACT_APP_BACKEND_URL=http://localhost:8000

# Google OAuth client ID from Google Cloud Console
REACT_APP_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# On Netlify, set this via Site Settings > Environment Variables:
# REACT_APP_BACKEND_URL=https://nutrition-backend-qire.onrender.com
# REACT_APP_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
